# Config env keys use double underscores for nesting: SECTION__KEY

# Database
DATABASE__URL=postgres://music:music@localhost:5432/music
DATABASE__SQLITE_PATH=./data/music.db
DATABASE__MAX_CONNECTIONS=10
DATABASE__MIN_CONNECTIONS=2

# Redis
REDIS__URL=redis://localhost:6379

# RabbitMQ
RABBITMQ__URL=amqp://guest:guest@localhost:5672

# JWT
JWT__SECRET=change-me-in-production
JWT__ACCESS_TTL_SECS=604800
JWT__REFRESH_TTL_SECS=604800
JWT__REMEMBER_ME_TTL_SECS=2592000

# Stream signing
STREAM__SIGNED_URL_TTL_SECS=604800

# Storage
STORAGE__BACKEND=local
STORAGE__LOCAL_PATH=./data/music
STORAGE__S3__ENDPOINT=http://localhost:3900
STORAGE__S3__ACCESS_KEY=
STORAGE__S3__SECRET_KEY=
STORAGE__S3__BUCKET=music
STORAGE__S3__REGION=us-west-1

# Service Ports (HTTP)
GATEWAY__PORT=8080
GATEWAY__RATE_LIMIT_REQUESTS=100
GATEWAY__RATE_LIMIT_WINDOW_SECS=60

# Service Ports (gRPC)
SERVICES__AUTH__GRPC_PORT=5051
SERVICES__CATALOG__GRPC_PORT=5052
SERVICES__STORAGE__GRPC_PORT=5053
SERVICES__STREAM__GRPC_PORT=5054
SERVICES__DOWNLOADS__GRPC_PORT=5055
SERVICES__SEARCH__GRPC_PORT=5056
SERVICES__PLAYLIST__GRPC_PORT=5057
SERVICES__ANALYTICS__GRPC_PORT=5058
SERVICES__DISCOVERY__GRPC_PORT=5059
SERVICES__RECOMMEND__GRPC_PORT=5060
SERVICES__TRANSCODING__GRPC_PORT=5061
SERVICES__INGESTION__GRPC_PORT=5062
SERVICES__HEARTBEAT__GRPC_PORT=5063
SERVICES__NOTIFICATION__GRPC_PORT=5064
SERVICES__SYNC__GRPC_PORT=5065

# Logging
LOGGING__LEVEL=info
LOGGING__FORMAT=pretty

# Transcoding
TRANSCODING__FFMPEG_PATH=ffmpeg
TRANSCODING__HLS_SEGMENT_DURATION=10
TRANSCODING__BITRATES=128,256,320
